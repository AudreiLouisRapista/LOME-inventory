* text=auto eol=lf

# --- PRIORITY 1 & 2: BLADE AND PHP ---
# We force these to be the most "detectable"
*.blade.php linguist-language=Blade
*.blade.php linguist-detectable=true
app/**/*.php linguist-detectable=true
*.php linguist-detectable=true

# --- PRIORITY 3: SMALL PERCENT CSS & JS ---
# We allow these extensions generally...
*.css linguist-detectable=true
*.js linguist-detectable=true
*.html linguist-detectable=true

# --- THE SECRET: HIDE THE HEAVY LIBRARIES ---
# This is what stops CSS from hitting 92%. It hides the "Big" files.
public/plugins/** linguist-vendored
public/dist/** linguist-vendored
public/build/** linguist-vendored
vendor/** linguist-vendored
node_modules/** linguist-vendored

# --- DO NOT COUNT THESE SPECIFIC FOLDERS ---
# Keeps the "HTML" percentage from getting too high
public/pages/** linguist-vendored

# --- OTHER SETTINGS ---
*.md diff=markdown
/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore
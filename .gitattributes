* text=auto eol=lf

*.blade.php diff=html
*.css diff=css
*.html diff=html
*.md diff=markdown
*.php diff=php

/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore

# --- 1. HIDE ALL MASSIVE FOLDERS ---
# This ignores the big library and compiled folders
public/plugins/** linguist-vendored
public/dist/** linguist-vendored
public/css/** linguist-vendored
public/pages/** linguist-vendored
vendor/** linguist-vendored
node_modules/** linguist-vendored

# --- 2. FORCE BLADE & PHP TO THE TOP ---
# This makes your logic and themes the "main" part of the repo
*.blade.php linguist-language=Blade
*.blade.php linguist-detectable
app/**/*.php linguist-detectable
resources/themes/**/*.blade.php linguist-detectable

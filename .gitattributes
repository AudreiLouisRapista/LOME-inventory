* text=auto eol=lf

# --- 1. THE LEADERS: BLADE & PHP ---
*.blade.php linguist-language=Blade
*.blade.php linguist-detectable=true
resources/**/*.blade.php linguist-detectable=true
app/**/*.php linguist-detectable=true
*.php linguist-detectable=true

# --- 2. THE SUPPORT: HTML & YOUR NEW CSS FOLDER ---
# This ensures ONLY your custom page styles show up
*.html linguist-detectable=true
public/css/pages/*.css linguist-detectable=true
public/css/admin_dp.css linguist-detectable=true
public/css/calendar.css linguist-detectable=true

# --- 3. THE "90% CSS KILLER" (VENDORED) ---
# This hides the thousands of lines from AdminLTE and plugins
public/plugins/** linguist-vendored
public/dist/** linguist-vendored
public/build/** linguist-vendored
vendor/** linguist-vendored
node_modules/** linguist-vendored

# --- 4. GLOBAL SILENCE FOR BLOAT ---
# This catches any stray CSS or JS files not in the folders above
*.js linguist-vendored
*.css linguist-vendored

# --- 5. CLEANUP ---
*.md diff=markdown
/.github export-ignore
CHANGELOG.md export-ignore
.styleci.yml export-ignore